{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run OpsBrain Backend",
      "type": "shell",
      "command": "npm start",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "opsbrain",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting OpsBrain|OpsBrain backend running",
          "endsPattern": "Open http://"
        }
      }
    }
  ]
}
